{
  "name": "openorg",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "conformance": "pnpm --filter @openorg/conformance test",
    "dev": "pnpm --filter @openorg/server dev",
    "dev:all": "node scripts/dev-all.mjs",
    "seed:golden": "node scripts/seed-golden.mjs",
    "lint": "eslint . && prettier --check .",
    "schemas": "pnpm --filter @openorg/protocol schemas",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
