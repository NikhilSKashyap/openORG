{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "olp.model-evaluation"
    },
    "contractVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "organizationId": {
      "type": "string",
      "minLength": 1
    },
    "suiteRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "caseId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "error"
            ]
          },
          "output": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "latencyMs": {
            "type": "number",
            "minimum": 0
          },
          "cost": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "currency": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3
              }
            },
            "required": [
              "amount",
              "currency"
            ],
            "additionalProperties": false
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "enum": [
                    "sha256",
                    "sha512"
                  ]
                },
                "digest": {
                  "type": "string",
                  "minLength": 1
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 1
                },
                "uri": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "algorithm",
                "digest"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "caseId",
          "status",
          "latencyMs",
          "evidenceRefs"
        ],
        "additionalProperties": false
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "totalCases": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "passedCases": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "passRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "averageLatencyMs": {
          "type": "number",
          "minimum": 0
        },
        "totalCost": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            }
          },
          "required": [
            "amount",
            "currency"
          ],
          "additionalProperties": false
        },
        "costCoverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "totalCases",
        "passedCases",
        "passRate",
        "averageLatencyMs",
        "costCoverage"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "organizationId",
    "suiteRef",
    "providerId",
    "modelId",
    "startedAt",
    "completedAt",
    "results",
    "metrics"
  ],
  "additionalProperties": false
}
