{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "olp.learning-proposal"
    },
    "contractVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "organizationId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "enum": [
        "rag",
        "evaluation",
        "preference",
        "policy",
        "training"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "withdrawn"
      ]
    },
    "sourceBindings": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "recordRef": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id",
              "version"
            ],
            "additionalProperties": false
          },
          "contentRef": {
            "type": "object",
            "properties": {
              "algorithm": {
                "type": "string",
                "enum": [
                  "sha256",
                  "sha512"
                ]
              },
              "digest": {
                "type": "string",
                "minLength": 1
              },
              "mediaType": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "algorithm",
              "digest"
            ],
            "additionalProperties": false
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "recordRef",
          "contentRef",
          "permissions"
        ],
        "additionalProperties": false
      }
    },
    "policyRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "version"
        ],
        "additionalProperties": false
      }
    },
    "consentRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "version"
        ],
        "additionalProperties": false
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "requestedBy": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "human"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "agent",
                "service"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        }
      ]
    },
    "proposedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "version",
    "organizationId",
    "workspaceId",
    "purpose",
    "status",
    "sourceBindings",
    "policyRefs",
    "consentRefs",
    "rationale",
    "requestedBy",
    "proposedAt"
  ],
  "additionalProperties": false
}
