{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "openorg.lineage-assertion"
    },
    "contractVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "from": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "to": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "relationship": {
      "default": "related_to",
      "type": "string",
      "enum": [
        "related_to",
        "derived_from",
        "supports",
        "contradicts",
        "constrains",
        "motivates",
        "authorizes",
        "commits_to",
        "implements",
        "produces",
        "verifies",
        "measures",
        "corrects",
        "supersedes"
      ]
    },
    "basis": {
      "type": "string",
      "enum": [
        "observed",
        "inferred",
        "asserted"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "proposed",
        "confirmed",
        "rejected",
        "superseded"
      ]
    },
    "authority": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "human"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "agent",
                "service"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "policy"
            },
            "ruleId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "ruleId"
          ],
          "additionalProperties": false
        }
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "enum": [
              "sha256",
              "sha512"
            ]
          },
          "digest": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "algorithm",
          "digest"
        ],
        "additionalProperties": false
      }
    },
    "correction": {
      "type": "object",
      "properties": {
        "original": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "id",
            "version"
          ],
          "additionalProperties": false
        },
        "corrected": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "id",
            "version"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "original",
        "corrected"
      ],
      "additionalProperties": false
    },
    "supersedes": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "assertedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "from",
    "to",
    "relationship",
    "basis",
    "state",
    "evidenceRefs",
    "assertedAt"
  ],
  "additionalProperties": false
}
