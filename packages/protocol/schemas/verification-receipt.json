{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "openorg.verification-receipt"
    },
    "contractVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "actor": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "human"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "agent",
                "service"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        }
      ]
    },
    "policyRef": {
      "type": "string",
      "minLength": 1
    },
    "requiredCheckIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "checkId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed"
            ]
          },
          "verifier": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "human"
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "displayName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "id"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "agent",
                      "service"
                    ]
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "version": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "kind",
                  "id"
                ],
                "additionalProperties": false
              }
            ]
          },
          "evidenceRefs": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "enum": [
                    "sha256",
                    "sha512"
                  ]
                },
                "digest": {
                  "type": "string",
                  "minLength": 1
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 1
                },
                "uri": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "algorithm",
                "digest"
              ],
              "additionalProperties": false
            }
          },
          "selfVerification": {
            "type": "boolean"
          }
        },
        "required": [
          "checkId",
          "status",
          "verifier",
          "evidenceRefs",
          "selfVerification"
        ],
        "additionalProperties": false
      }
    },
    "humanApprovals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gateId": {
            "type": "string",
            "minLength": 1
          },
          "approver": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "human"
              },
              "id": {
                "type": "string",
                "minLength": 1
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "id"
            ],
            "additionalProperties": false
          },
          "approvedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          }
        },
        "required": [
          "gateId",
          "approver",
          "approvedAt"
        ],
        "additionalProperties": false
      }
    },
    "rejectedAlternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "algorithm": {
                  "type": "string",
                  "enum": [
                    "sha256",
                    "sha512"
                  ]
                },
                "digest": {
                  "type": "string",
                  "minLength": 1
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 1
                },
                "uri": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "algorithm",
                "digest"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "description",
          "reason",
          "evidenceRefs"
        ],
        "additionalProperties": false
      }
    },
    "measuredOutcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "measuredAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          }
        },
        "required": [
          "metric",
          "value",
          "unit",
          "measuredAt"
        ],
        "additionalProperties": false
      }
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "workspace",
    "subject",
    "actor",
    "policyRef",
    "requiredCheckIds",
    "verdicts",
    "humanApprovals",
    "rejectedAlternatives",
    "measuredOutcomes",
    "recordedAt"
  ],
  "additionalProperties": false
}
