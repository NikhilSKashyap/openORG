{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "openorg.dataset-manifest"
    },
    "contractVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "organizationId": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "enum": [
        "rag",
        "evaluation",
        "preference",
        "sft"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "createdBy": {
      "type": "string",
      "minLength": 1
    },
    "policyRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recordRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "version"
        ],
        "additionalProperties": false
      }
    },
    "schemaVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inclusion": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contentRef": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512"
          ]
        },
        "digest": {
          "type": "string",
          "minLength": 1
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "algorithm",
        "digest"
      ],
      "additionalProperties": false
    },
    "split": {
      "type": "object",
      "properties": {
        "train": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "test": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "train",
        "validation",
        "test"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "organizationId",
    "purpose",
    "createdAt",
    "createdBy",
    "policyRefs",
    "recordRefs",
    "schemaVersions",
    "inclusion",
    "exclusions",
    "contentRef"
  ],
  "additionalProperties": false
}
