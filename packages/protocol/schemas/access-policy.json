{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "openorg.access-policy"
    },
    "contractVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "organizationId": {
      "type": "string",
      "minLength": 1
    },
    "defaultEffect": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "effect": {
            "type": "string",
            "enum": [
              "allow",
              "deny"
            ]
          },
          "actions": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "record.read",
                "record.write",
                "lineage.read",
                "lineage.write",
                "provider.read",
                "provider.manage",
                "skill.manage",
                "skill.invoke",
                "export.rag",
                "export.evaluation",
                "export.preference",
                "export.sft",
                "learning.evaluate",
                "learning.train",
                "learning.route",
                "learning.promote",
                "policy.approve"
              ]
            }
          },
          "principalIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requiredPermissions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "recordTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "classifications": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "public",
                "internal",
                "confidential",
                "restricted"
              ]
            }
          },
          "purposes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "destinationKinds": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "same_process",
                "organization_vpc",
                "external"
              ]
            }
          },
          "requireConsent": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "effect",
          "actions",
          "principalIds",
          "requiredPermissions",
          "recordTypes",
          "classifications",
          "purposes",
          "destinationKinds",
          "requireConsent"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "version",
    "organizationId",
    "defaultEffect",
    "createdAt",
    "rules"
  ],
  "additionalProperties": false
}
