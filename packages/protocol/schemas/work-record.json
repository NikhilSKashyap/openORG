{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "openorg.work-record"
    },
    "contractVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "actor": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "human"
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "agent",
                "service"
              ]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "kind",
            "id"
          ],
          "additionalProperties": false
        }
      ]
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "decisionRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "tool",
              "model",
              "skill"
            ]
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "id",
          "version",
          "hash"
        ],
        "additionalProperties": false
      }
    },
    "contextRef": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "type": "string",
            "enum": [
              "create",
              "update",
              "delete",
              "execute"
            ]
          },
          "before": {
            "type": "object",
            "properties": {
              "algorithm": {
                "type": "string",
                "enum": [
                  "sha256",
                  "sha512"
                ]
              },
              "digest": {
                "type": "string",
                "minLength": 1
              },
              "mediaType": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "algorithm",
              "digest"
            ],
            "additionalProperties": false
          },
          "after": {
            "type": "object",
            "properties": {
              "algorithm": {
                "type": "string",
                "enum": [
                  "sha256",
                  "sha512"
                ]
              },
              "digest": {
                "type": "string",
                "minLength": 1
              },
              "mediaType": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": [
              "algorithm",
              "digest"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "target",
          "operation"
        ],
        "additionalProperties": false
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "additionalProperties": false
    },
    "latencyMs": {
      "type": "number",
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string",
            "enum": [
              "sha256",
              "sha512"
            ]
          },
          "digest": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "algorithm",
          "digest"
        ],
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        }
      },
      "required": [
        "source",
        "capturedAt"
      ],
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "hmac-sha256"
        },
        "keyId": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "algorithm",
        "keyId",
        "value"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "contract",
    "contractVersion",
    "id",
    "version",
    "workspace",
    "recordedAt",
    "actor",
    "action",
    "decisionRef",
    "components",
    "contextRef",
    "changes",
    "artifacts",
    "provenance"
  ],
  "additionalProperties": false
}
