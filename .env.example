OPENORG_WORKSPACE_KEY=replace-with-a-local-secret
OPENORG_WORKSPACE_KEY_ID=local-workspace
OPENORG_DB_PATH=.openorg/records.db
OPENORG_POLICY_RULE_IDS=
OPENORG_SECURITY_MODE=local
# In enforced mode, supply versioned policy and API-key principal arrays.
# OPENORG_ACCESS_POLICY_JSON={...}
# OPENORG_API_KEYS_JSON=[{"token":"...","principal":{"identity":{"kind":"human","id":"..."},"organizationId":"...","permissions":[]}}]
